{
  "name": "ag0-template-diagramming-agent",
  "version": "0.1.0",
  "description": "A local web studio for editing .excalidraw files",
  "bin": {
    "diagramming": "./dist/bin/diagramming.js"
  },
  "scripts": {
    "build:client": "vite build",
    "build": "bun run build:client",
    "dev": "concurrently -n vite,server -c cyan,magenta \"vite\" \"bun run server/dev.ts\"",
    "dev:server": "bun run server/dev.ts",
    "studio": "bun run bin/diagramming.ts studio"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.17.6",
    "commander": "^12.1.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "fast-glob": "^3.3.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  },
  "type": "module"
}
